# APPLE_PRIVATE_KEY is the contents of the .p8 key Apple gives you for that Services ID
# Return URL registered with Apple: http://127.0.0.1:5000/auth/apple/callback
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
